# Clock + CPU/outdoor temperature cycle
LED_PROFILE_NAME=weather
LED_TIME_ALIGN=right
LED_INFO_ENABLE=0
LED_DRAW_TEMP=1
LED_TEMP_SHOW_C=1

# Alternate CPU and outdoor temps
LED_TEMP_CYCLE_ENABLE=1
LED_TEMP_CYCLE_ITEMS=cpu,outdoor
LED_TEMP_CYCLE_EVERY=10

# Open-Meteo (set your location)
LED_WEATHER_ENABLE=1
LED_WEATHER_PROVIDER=open-meteo
LED_WEATHER_LAT=55.7558
LED_WEATHER_LON=37.6176
LED_WEATHER_REFRESH=1800
LED_WEATHER_TIMEOUT=4

# Keep display calm
LED_TICKER_EVERY=999999
LED_SECONDS_BAR=1
LED_SECONDS_BAR_DOTTED=0
LED_SPARKLE_ON_HOUR=0
LED_MINUTE_SWIPE=0
LED_AUTO_DIM=1
LED_BRIGHTNESS_DAY=12
LED_BRIGHTNESS_NIGHT=3
